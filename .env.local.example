# YouTube Data API v3 Key
# Google Cloud Console'dan alınır: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_YOUTUBE_API_KEY=YOUR_API_KEY_HERE

# API-Football (api-sports.io)
# Ücretsiz plan: 100 req/gün — https://dashboard.api-football.com/
FOOTBALL_API_KEY=YOUR_API_FOOTBALL_KEY_HERE

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Google AdSense
# adsense.google.com'dan başvuru yapıp onay alınca Publisher ID'yi girin
# Format: ca-pub-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=

# AdSense Ad Unit Slot ID'leri (opsiyonel — her alan için ayrı reklam birimi)
# AdSense panelinden "Reklam birimleri" oluşturup slot ID'lerini buraya girin
NEXT_PUBLIC_AD_SLOT_SIDEBAR=
NEXT_PUBLIC_AD_SLOT_PLAYER=
NEXT_PUBLIC_AD_SLOT_CHAT=
NEXT_PUBLIC_AD_SLOT_STATS=
NEXT_PUBLIC_AD_SLOT_STREAM=
